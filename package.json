  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@blit386/kit": "^1.2.0",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
